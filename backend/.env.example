PORT=3000
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DB_PATH=./data/app.db

# 本机挂代理时填写（国内网络访问 Google 系博客 / YouTube 等需要），不挂则留空
# YOUTUBE_PROXY_URL=http://127.0.0.1:7897
# HTTP_PROXY=http://127.0.0.1:7897
# HTTPS_PROXY=http://127.0.0.1:7897
# NO_PROXY=localhost,127.0.0.1

# 飞书接入（ADR-039）：自建应用凭证，用于只读拉取云文档/妙记/群聊/知识库进灵感库·素材库。
# 在开放平台建（或复用现有）自建应用 → 加读权限 docx/minutes/im:message/wiki(readonly) → 发版；
# 不填则飞书接入自动关闭、其它功能不受影响。
# FEISHU_APP_ID=cli_xxxxxxxx
# FEISHU_APP_SECRET=xxxxxxxx
# FEISHU_BASE=https://open.feishu.cn          # 默认飞书·中国；国际版 Lark 填 https://open.larksuite.com
# FEISHU_SOURCES=docx,im,wiki                  # 被动 sync 拉哪些来源（妙记无列表接口，走"从飞书选/粘链接"）
# FEISHU_DOC_FOLDER_TOKEN=                     # 只扫这个云文档文件夹（缺省=根目录）
# FEISHU_WIKI_SPACE_ID=                        # 只扫这个知识库空间（缺省=应用可见的全部）
# FEISHU_IM_CHAT_IDS=                          # 逗号分隔，只拉这些群（缺省=机器人所在全部群）
